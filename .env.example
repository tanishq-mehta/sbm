# Use this when you are ready to connect Supabase/Postgres.
# Keep your real .env private and do not commit it.
DATABASE_URL="postgresql://postgres.your-project-ref:your-password@aws-0-region.pooler.supabase.com:6543/postgres"

# Supabase requires SSL for remote Postgres connections. Leave this as true.
DATABASE_SSL=true

# Authentication is configured outside the repo.
# Generate one user entry with:
# npm run auth:user -- admin "choose-a-strong-password"
#
# For multiple users, put the generated entries in one JSON array:
# AUTH_USERS_JSON='[{"username":"admin","passwordHash":"pbkdf2_sha256$..."}]'
AUTH_USERS_JSON=''

# Generate with:
# npm run auth:secret
AUTH_SECRET=''
