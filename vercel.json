{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/router?path=:path*"
    }
  ],
  "functions": {
    "api/router.mjs": {
      "maxDuration": 10,
      "includeFiles": "data/**"
    }
  }
}
